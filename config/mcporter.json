      "description": "\u9ad8\u5fb7\u5730\u56fe MCP",
      "command": "npx",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
        "AMAP_MAPS_API_KEY": "a1251a0acdd54d98189e5cb6a592c102"
      },
